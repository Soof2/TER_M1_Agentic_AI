# Copier ce fichier en .env et remplir les valeurs
# Le fichier .env ne doit PAS être commité (voir .gitignore)

# ---------------------------------------------------------------------------
# Modèle LLM Groq (obligatoire pour Docker)
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Créer une clé sur https://console.groq.com
GROQ_API_KEY=gsk_...

# Alternative en cas de quota ou de besoin de modèle plus léger :
# LLM_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# APIs externes (toutes GRATUITES)
# ---------------------------------------------------------------------------
# GitHub token (optionnel) — sans token : 60 req/h, avec : 5 000 req/h
# Créer gratuitement sur https://github.com/settings/tokens (scope: aucun requis)
GITHUB_TOKEN=

# Stack Overflow key (optionnel) — sans clé : 300 req/jour, avec : 10 000 req/jour
# Créer gratuitement sur https://stackapps.com/apps/oauth/register
STACKOVERFLOW_KEY=

# ---------------------------------------------------------------------------
# RAG / Mémoire vectorielle
# ---------------------------------------------------------------------------
# Dossier de persistance ChromaDB (créé automatiquement)
# CHROMADB_DIR=./data/chromadb

# Base SQLite des runs API (historique UI/API)
# RUNS_DB_PATH=./data/runs.sqlite

# ---------------------------------------------------------------------------
# Seuils de scoring (optionnel — valeurs par défaut déjà raisonnables)
# ---------------------------------------------------------------------------
# SCORE_SEUIL_CONTACT=75
# SCORE_SEUIL_VIABLE=40
# TOP_N_RELATIF=3
# MAX_PROFILS_RECHERCHE=15
